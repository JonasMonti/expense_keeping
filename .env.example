# Copia este ficheiro para ".env" e ajusta conforme necessário.

# Base de dados.
# Por defeito (se não definires nada) usa SQLite num ficheiro local: expenses.db
#
# Para PostgreSQL (precisa do driver: pip install "psycopg[binary]"):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/expenses
#
# Para SQLite explícito:
# DATABASE_URL=sqlite:///expenses.db

# Moeda usada na interface
APP_CURRENCY=€
