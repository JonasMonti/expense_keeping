<?xml version="1.0" encoding="utf-8"?>
<!--
  Regras de cópia de dados (Android 12+, API 31+).
  - cloud-backup: cópia para o Google Drive do utilizador (reinstalar/novo telemóvel).
  - device-transfer: cópia direta telemóvel-a-telemóvel.
  Em ambos os casos inclui a base de dados SQLite (expenses.db) e as preferências.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
